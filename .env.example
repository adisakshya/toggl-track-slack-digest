# Copy this file to .env for local development. Never commit .env.
#
# Required
# --------

# Toggl Track API token. Find it at https://track.toggl.com/profile
TOGGL_API_TOKEN=your_toggl_api_token_here

# Toggl workspace id whose projects/entries should be pulled.
TOGGL_WORKSPACE_ID=1234567

# Slack Incoming Webhook URL. Create one at https://api.slack.com/apps
# under "Incoming Webhooks" for the target channel.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK

# Optional
# --------

# Number of trailing days the digest covers. Defaults to 7.
DIGEST_PERIOD_DAYS=7

# Comma-separated Toggl project ids to include. Empty/unset = all projects.
TOGGL_PROJECT_IDS=

# IANA timezone used for date range computation and display. Defaults to UTC.
TIMEZONE=UTC

# Any single day at or above this many tracked hours is flagged as a likely
# forgotten running timer in the digest. Defaults to 16.
ANOMALY_THRESHOLD_HOURS=16
